#!/usr/bin/env bash
# Interactive shell configuration (Linux)

# Homebrew update policy (ADR 0026): make routine updates deliberate instead of
# a side effect of installing. NO_AUTO_UPDATE stops the implicit `brew update`
# on install; NO_INSTALL_UPGRADE stops `brew install` from upgrading existing
# formulae; NO_INSTALLED_DEPENDENTS_CHECK stops the post-install auto-upgrade of
# outdated dependents after the requested operation; CASK_OPTS=--require-sha
# refuses casks without a checksum (macOS-relevant; inert on Linux). Plan
# visibility (ask mode) is the current Homebrew default; HOMEBREW_ASK is a
# deprecated compatibility variable and must not be set. Security fixes bypass this — see
# docs/security.md "When to bypass the cooldown".
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_INSTALL_UPGRADE=1
export HOMEBREW_NO_INSTALLED_DEPENDENTS_CHECK=1
export HOMEBREW_CASK_OPTS=--require-sha

export ASDF_CONFIG_FILE="$HOME/.config/asdf/.asdfrc"

# Linuxbrew shellenv
if [[ -e /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# asdf (Linuxbrew-installed; v0.16+ Go binary — no asdf.sh)
# https://asdf-vm.com/guide/getting-started.html
# PATH order: asdf shim is prepended here, but later `~/.local/bin` / `~/.cargo/bin`
# / `~/.bun/bin` prepends push it back. Final PATH = native installers > asdf shim.
# This is intentional (native installers win for overlapping tools; asdf acts as
# an overlay — see ADR 0023). To use the asdf-pinned version of an overlapping
# tool, run `asdf exec <tool>` / `asdf shell <tool> <version>`.
if command -v asdf &>/dev/null; then
    export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
    . <(asdf completion bash)
    # asdf-java JAVA_HOME hook (parity with fish set-java-home.fish)
    [[ -f "$HOME/.asdf/plugins/java/set-java-home.bash" ]] \
        && . "$HOME/.asdf/plugins/java/set-java-home.bash"
fi

# Local bin (uv installer puts uv here)
[[ -d "$HOME/.local/bin" ]] && PATH="$HOME/.local/bin:$PATH"

# Rust (rustup)
[[ -d "$HOME/.cargo/bin" ]] && PATH="$HOME/.cargo/bin:$PATH"

# Bun
export BUN_INSTALL="$HOME/.bun"
[[ -d "$BUN_INSTALL/bin" ]] && PATH="$BUN_INSTALL/bin:$PATH"

# Starship prompt
command -v starship &>/dev/null && eval "$(starship init bash)"

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook bash)"

# fzf key bindings (Ctrl-R, Ctrl-T, Alt-C) + completion
if [[ -n "$HOMEBREW_PREFIX" && -f "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.bash" ]]; then
    source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.bash"
fi
if [[ -n "$HOMEBREW_PREFIX" && -f "$HOMEBREW_PREFIX/opt/fzf/shell/completion.bash" ]]; then
    source "$HOMEBREW_PREFIX/opt/fzf/shell/completion.bash"
fi

# Aliases (translated from fish abbr/function)
alias be='bundle exec'
alias cm='chezmoi'
alias d='docker'
alias dc='docker compose'
alias gd='git diff-delta'
alias gst='git status'
alias l='eza -ahl --git'
alias ll='ls -ahl'
alias tree='eza -T'

# SSH agent: always prefer the systemd user ssh-agent socket when it exists.
# This box is GitHub-only with no agent forwarding (ADR 0027), so we deliberately ignore any inherited
# SSH_AUTH_SOCK — a stray forwarded or broader-scoped agent is never used here, and a stale inherited
# value cannot silently block git. No-op (keeps the inherited value) on machines without the service.
_ssh_agent_sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"
if [[ -S "$_ssh_agent_sock" ]]; then
    export SSH_AUTH_SOCK="$_ssh_agent_sock"
fi
unset _ssh_agent_sock

# Machine-specific overrides
[[ -f "$HOME/.bashrc.local" ]] && source "$HOME/.bashrc.local"
