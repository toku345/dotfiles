{
  "env": {
    "EDITOR": "code-insiders --wait",
    "VISUAL": "code-insiders --wait"
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git fetch:*)",
      "Bash(tree:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(npm run *)",
      "Bash(npm test:*)",
      "Bash(npm list:*)",
      "Bash(npm install:*)",
      "Bash(yarn run *)",
      "Bash(yarn test:*)",
      "Bash(yarn add:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "Bash(cargo add:*)",
      "Bash(jq:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi status:*)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.nvidia.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:registry.yarnpkg.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:developer.mozilla.org)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "NotebookEdit",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.envrc)",
      "Edit(.netrc)",
      "Edit(.npmrc)",
      "Edit(id_ed25519)",
      "Edit(id_ed25519.*)",
      "Edit(id_rsa)",
      "Edit(id_rsa.*)",
      "Edit(~/.aws/config)",
      "Edit(~/.aws/credentials)",
      "Edit(~/.config/gh/hosts.yml)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.kube/config)",
      "Edit(~/.netrc)",
      "Edit(~/.npmrc)",
      "Edit(~/.ssh/id_rsa)",
      "Edit(~/.ssh/id_rsa.pub)",
      "Edit(~/.ssh/id_ed25519)",
      "Edit(~/.ssh/id_ed25519.pub)",
      "Edit(~/.ssh/config)",
      "Edit(~/.ssh/known_hosts)",
      "Edit(~/.ssh/authorized_keys)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.envrc)",
      "Read(.netrc)",
      "Read(.npmrc)",
      "Read(id_ed25519)",
      "Read(id_ed25519.*)",
      "Read(id_rsa)",
      "Read(id_rsa.*)",
      "Read(~/.aws/config)",
      "Read(~/.aws/credentials)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/id_rsa)",
      "Read(~/.ssh/id_rsa.pub)",
      "Read(~/.ssh/id_ed25519)",
      "Read(~/.ssh/id_ed25519.pub)",
      "Read(~/.ssh/config)",
      "Read(~/.ssh/known_hosts)",
      "Read(~/.ssh/authorized_keys)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(.envrc)",
      "Write(.netrc)",
      "Write(.npmrc)",
      "Write(id_ed25519)",
      "Write(id_ed25519.*)",
      "Write(id_rsa)",
      "Write(id_rsa.*)",
      "Write(secrets/)",
      "Write(~/.aws/config)",
      "Write(~/.aws/credentials)",
      "Write(~/.config/gh/hosts.yml)",
      "Write(~/.docker/config.json)",
      "Write(~/.kube/config)",
      "Write(~/.netrc)",
      "Write(~/.npmrc)",
      "Write(~/.ssh/id_rsa)",
      "Write(~/.ssh/id_rsa.pub)",
      "Write(~/.ssh/id_ed25519)",
      "Write(~/.ssh/id_ed25519.pub)",
      "Write(~/.ssh/config)",
      "Write(~/.ssh/known_hosts)",
      "Write(~/.ssh/authorized_keys)"
    ],
    "ask": [
      "Bash(chmod +x:*)",
      "Bash(claude config:*)",
      "Bash(curl:*)",
      "Bash(gh api:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -m:*)",
      "Bash(git branch -M:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(rm:*)",
      "Bash(wget:*)",
      "Bash(chezmoi apply:*)",
      "WebSearch"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null && afplay /System/Library/Sounds/Glass.aiff || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowRead": [
        "~/.ssh/known_hosts",
        "~/.ssh/config",
        "~/.ssh/config.local",
        "~/.orbstack/ssh/config"
      ],
      "allowWrite": [
        "/tmp",
        "~/.ssh/known_hosts"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowAllUnixSockets": true
    },
    "enableWeakerNestedSandbox": true,
    "excludedCommands": [
      "docker",
      "gh",
      "codex"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": false
}
