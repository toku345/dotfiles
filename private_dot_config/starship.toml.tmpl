# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

add_newline = true
scan_timeout = 100
command_timeout = 5000

{{- if eq .chezmoi.os "linux" }}
# ===== Linux: Bracketed Segments preset (Unicode box-drawing, no Nerd Font glyphs) =====

format = """
[έΦΝέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑέΦΑ](bold green)
[έΦΓ](bold green)$directory$git_branch$git_status$character
"""

[character]
success_symbol = "[έζψ](bold green)"
error_symbol = "[έζψ](bold red)"

[hostname]
ssh_only = true
format = "[$ssh_symbol$hostname]($style) "
style = "bold blue"

{{- else if eq .chezmoi.os "darwin" }}
# ===== macOS: Nerd Font Symbols Preset =====

[character]
success_symbol = "[έηε](bold green)"
error_symbol = "[έεΩ](bold red)"

